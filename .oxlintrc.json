{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "jsx-a11y"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    // The trigger is a <span role="button"> and the dialog is a <div role="dialog">
    // on purpose: the trigger wraps arbitrary children (often a real <button>, which
    // can't be nested), and the dialog is portalled with a custom halo layer rather
    // than the native <dialog> element.
    "jsx-a11y/prefer-tag-over-role": "off",
    // The full-screen overlay is a click-to-dismiss backdrop; Escape is the keyboard
    // equivalent, so it needs neither a role nor key handlers of its own.
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/click-events-have-key-events": "off"
  }
}
